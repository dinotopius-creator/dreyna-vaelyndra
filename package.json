  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npm run android:sync && npx cap run android",
    "android:build:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:build:release": "npm run android:sync && cd android && gradlew.bat assembleRelease",
    "android:build:bundle": "npm run android:sync && cd android && gradlew.bat bundleRelease",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
